match_clause:
  patterns:
    - elements:
        - Node:
            variable: n
            labels:
              - Person
            properties: []
where_clause: ~
return_clause:
  distinct: false
  items:
    - expression:
        Aggregate:
          func: Min
          distinct: false
          expr:
            Property:
              variable: n
              property: age
      alias: ~
    - expression:
        Aggregate:
          func: Max
          distinct: false
          expr:
            Property:
              variable: n
              property: age
      alias: ~
order_clause: ~
limit_clause: ~
