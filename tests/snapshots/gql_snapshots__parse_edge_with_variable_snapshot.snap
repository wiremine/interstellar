match_clause:
  patterns:
    - elements:
        - Node:
            variable: a
            labels: []
            properties: []
        - Edge:
            variable: r
            labels:
              - KNOWS
            direction: Outgoing
            quantifier: ~
            properties: []
        - Node:
            variable: b
            labels: []
            properties: []
where_clause: ~
return_clause:
  distinct: false
  items:
    - expression:
        Variable: a
      alias: ~
    - expression:
        Variable: r
      alias: ~
    - expression:
        Variable: b
      alias: ~
group_by_clause: ~
order_clause: ~
limit_clause: ~
