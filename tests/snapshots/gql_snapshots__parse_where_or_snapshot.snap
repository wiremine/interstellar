where_clause:
  expression:
    BinaryOp:
      left:
        BinaryOp:
          left:
            Property:
              variable: n
              property: city
          op: Eq
          right:
            Literal:
              String: NYC
      op: Or
      right:
        BinaryOp:
          left:
            Property:
              variable: n
              property: city
          op: Eq
          right:
            Literal:
              String: LA
let_clauses: []
return_clause:
  distinct: false
  items:
    - expression:
        Variable: n
      alias: ~
group_by_clause: ~
having_clause: ~
